{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-sticky-todo",
  "version": "0.1.0",
  "identifier": "com.chaoqunwangcs.desktop-sticky-todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "桌面待办与日历 — 设置",
        "width": 480,
        "height": 560,
        "minWidth": 400,
        "minHeight": 480,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true,
        "focus": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
