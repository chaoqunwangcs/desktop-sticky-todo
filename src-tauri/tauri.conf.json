{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-sticky-todo",
  "version": "0.1.0",
  "identifier": "com.chaoqunwangcs.desktop-sticky-todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Desktop Sticky Todo",
        "width": 760,
        "height": 620,
        "minWidth": 380,
        "minHeight": 420,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
